{
  "name": "@blackrock-ai/agent-runtime",
  "version": "0.1.2",
  "description": "Agent Core orchestrator — planner, executor, synthesizer, critic. Deploys into the client's own Supabase Edge Functions.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./edge": { "import": "./dist/edge.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsup --config tsup.edge.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@blackrock-ai/agent-tools": "workspace:*",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackrock-ai/blackrock-agent-core.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/blackrock-ai/blackrock-agent-core#readme",
  "bugs": {
    "url": "https://github.com/blackrock-ai/blackrock-agent-core/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
